# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/skillbridge

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000
PORT=3000

# Midtrans (replace with sandbox keys)
MIDTRANS_SERVER_KEY=your_midtrans_server_key
MIDTRANS_CLIENT_KEY=your_midtrans_client_key

# Auth / secrets
NEXTAUTH_SECRET=replace_with_random_string
JWT_SECRET=replace_with_random_string

# Prisma
# (If using Prisma, keep the DATABASE_URL above)
